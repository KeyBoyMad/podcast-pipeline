# 复制本文件为 .env，填入真实 Key，.env 已被 .gitignore 排除，不会提交到 Git
# cp .env.example .env

# ── LLM Provider（至少配置一个）──────────────────────────────
# 优先级：Anthropic > Gemini > DeepSeek > SiliconFlow > Groq
# 程序会自动检测已设置的第一个 Key

# Anthropic Claude（付费）
# 申请：https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# Google Gemini（免费套餐 15 RPM）
# 申请：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza

# DeepSeek（国内，免费额度，中文效果最佳）
# 申请：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-

# SiliconFlow 硅基流动（国内，注册送额度，支持 DeepSeek/Qwen 等多模型）
# 申请：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=sk-

# Groq（境外，免费套餐 30 RPM，速度极快）
# 申请：https://console.groq.com
GROQ_API_KEY=gsk_

# ── 可选：指定 ffmpeg 路径（未加入 PATH 时使用）────────────────
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
